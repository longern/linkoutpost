{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "linkoutpost",
  "main": "./src/worker.tsx",
  "compatibility_date": "2026-07-03",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
    "binding": "ASSETS",
    "run_worker_first": ["/*", "!/", "!/assets/*", "!/admin", "!/admin/*"]
  }
}
